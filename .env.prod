# Application
APP_NAME=Intelli Document Platform
DEBUG=false
LOG_LEVEL=WARNING

# Database
DATABASE_URL=postgresql+asyncpg://intelli:intelli@localhost:5433/intelli
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Storage (S3/MinIO)
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=intelli-artifacts
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# For local file storage (alternative to S3)
# STORAGE_BACKEND=local
# LOCAL_STORAGE_PATH=/tmp/intelli-storage

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=

# LLM (for RAG answers)
CHAT_MODEL=gpt-4o-mini

# Index backend (search + retrieval)
# For the current demo:
# - pgvector: store chunk embeddings in Postgres
# - opensearch: store chunk embeddings + BM25 in OpenSearch (recommended "real service")
INDEX_BACKEND=opensearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_CHUNKS_INDEX=intelli-chunks-v1

# MCP Server
MCP_TRANSPORT=streamable-http
MCP_PORT=8001

# Security
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-openssl-rand-hex-32
JWT_EXPIRY_HOURS=24
CORS_ORIGINS=["http://localhost:3000"]
RATE_LIMIT_RPM=60

# Observability (optional)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
