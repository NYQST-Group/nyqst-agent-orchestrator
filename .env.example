# Application
APP_NAME=Intelli Document Platform
DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://intelli:intelli@localhost:5432/intelli
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Storage (S3/MinIO)
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=intelli-artifacts
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# For local file storage (alternative to S3)
# STORAGE_BACKEND=local
# LOCAL_STORAGE_PATH=/tmp/intelli-storage

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=

# MCP Server
MCP_TRANSPORT=streamable-http
MCP_PORT=8001

# Observability (optional)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
